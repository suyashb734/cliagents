{
  "name": "cliagents",
  "version": "0.1.0-alpha.0",
  "private": true,
  "description": "Local broker for Claude Code, Codex CLI, Gemini CLI, Qwen CLI, and OpenCode with durable orchestration, memory, usage, and inspection APIs.",
  "main": "src/index.js",
  "bin": {
    "cliagents": "bin/cliagents.js"
  },
  "type": "commonjs",
  "scripts": {
    "start": "node scripts/run-with-supported-node.js src/index.js",
    "dev": "node scripts/run-with-supported-node.js --node-arg=--watch src/index.js",
    "supervise:task": "node scripts/run-with-supported-node.js scripts/task-supervisor-harness.js",
    "setup": "node src/scripts/setup-auth.js",
    "test": "node scripts/run-with-supported-node.js tests/test-focused-surface.js",
    "test:focused": "node scripts/run-with-supported-node.js tests/test-focused-surface.js",
    "test:runtime": "node scripts/run-with-supported-node.js tests/test-runtime-consistency.js",
    "test:broad": "node scripts/run-with-supported-node.js tests/test-broad-api-surface.js",
    "smoke:deterministic": "node scripts/run-with-supported-node.js scripts/deterministic-smoke-suite.js",
    "test:rooms:live": "node scripts/run-with-supported-node.js tests/test-room-continuity-live.js",
    "release:check": "node scripts/run-with-supported-node.js scripts/release-check.js"
  },
  "keywords": [
    "ai",
    "agent",
    "cli",
    "gemini",
    "codex",
    "qwen",
    "orchestration",
    "consensus",
    "mcp",
    "api",
    "rest",
    "websocket",
    "streaming",
    "llm"
  ],
  "author": "suyashb734",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/suyashb734/cliagents.git"
  },
  "bugs": {
    "url": "https://github.com/suyashb734/cliagents/issues"
  },
  "homepage": "https://github.com/suyashb734/cliagents#readme",
  "engines": {
    "node": "22.12.0"
  },
  "files": [
    "bin",
    "src",
    "public",
    "config",
    "openapi.json",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@google/genai": "^1.40.0",
    "better-sqlite3": "^12.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.2",
    "openai": "^4.0.0",
    "ws": "^8.14.2"
  },
  "pnpm": {
    "overrides": {
      "protobufjs": "7.5.7"
    }
  },
  "packageManager": "pnpm@10.28.2+sha512.41872f037ad22f7348e3b1debbaf7e867cfd448f2726d9cf74c08f19507c31d2c8e7a11525b983febc2df640b5438dee6023ebb1f84ed43cc2d654d2bc326264"
}
