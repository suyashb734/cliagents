# cliagents environment variables
# Copy to .env for local development. Do not commit real secrets.

# Server bind configuration
PORT=4001
CLIAGENTS_HOST=127.0.0.1

# Authentication
# Preferred explicit API key for shared or remote clients.
# CLIAGENTS_API_KEY=replace-with-a-long-random-token
# Legacy alias also supported:
# CLI_AGENTS_API_KEY=replace-with-a-long-random-token

# Local broker token path. When no explicit API key is configured, cliagents
# creates a same-machine token at $CLIAGENTS_DATA_DIR/local-api-key.
# CLIAGENTS_LOCAL_API_KEY_FILE=./data/local-api-key

# Development-only unauthenticated loopback mode. Never use with non-loopback
# hosts or tunnels.
# CLIAGENTS_ALLOW_UNAUTHENTICATED_LOCALHOST=1

# Storage and runtime paths
CLIAGENTS_DATA_DIR=./data
CLIAGENTS_LOG_DIR=./logs
# CLIAGENTS_TMUX_SOCKET=/tmp/cliagents/broker.sock
# CLIAGENTS_WORK_DIR=/path/to/default/workspace
# CLIAGENTS_DESTROY_TERMINALS_ON_STOP=0

# API CORS policy
# CLIAGENTS_API_CORS_ALLOWED_ORIGINS=http://localhost:3000
# CLIAGENTS_API_CORS_ALLOW_LOOPBACK=1

# Dashboard environment mutation
# CLIAGENTS_DISABLE_DASHBOARD_ENV_MUTATION=1
# CLIAGENTS_DASHBOARD_ENV_MUTATION_EXTRA_KEYS=EXTRA_PROVIDER_KEY

# Provider CLI hints. Prefer each provider's normal local auth flow when
# available; only set API keys here when that provider CLI requires them.
# ANTHROPIC_API_KEY=your-anthropic-key
# OPENAI_API_KEY=your-openai-key
# GEMINI_API_KEY=your-gemini-key
# GOOGLE_API_KEY=your-google-key
# OPENROUTER_API_KEY=your-openrouter-key

# Adapter path overrides
# CLIAGENTS_CLAUDE_PATH=/absolute/path/to/claude
# CLIAGENTS_CODEX_PATH=/absolute/path/to/codex
# CLIAGENTS_GEMINI_PATH=/absolute/path/to/gemini
# CLIAGENTS_QWEN_PATH=/absolute/path/to/qwen
# CLIAGENTS_OPENCODE_PATH=/absolute/path/to/opencode
